{
  "version": 2,
  "builds": [
    {
      "src": "backend/api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    },
    {
      "src": "admin-panel/**",
      "use": "@vercel/static"
    },
    {
      "src": "technician-panel/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/api/index.js"
    },
    {
      "src": "/admin/(.*)",
      "dest": "/admin-panel/$1"
    },
    {
      "src": "/technician/(.*)",
      "dest": "/technician-panel/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/$1"
    }
  ]
}
