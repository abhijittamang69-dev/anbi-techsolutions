# ANBI Tech Solution - Environment Configuration
NODE_ENV=production
PORT=10000

# MongoDB Atlas (MongoDB Cloud)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/anbi-tech?retryWrites=true&w=majority

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d

# Email (Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=anbitechsolutions@gmail.com
SMTP_PASS=your-gmail-app-password-here
ADMIN_EMAIL=anbitechsolutions@gmail.com

# Cloudinary (File Uploads)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Frontend URL (Render domain)
FRONTEND_URL=https://anbi-tech.onrender.com
