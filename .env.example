# ANBI Tech Solution - Environment Configuration
# =============================================================================
# INSTRUCTIONS:
# 1. Copy this file to .env:  cp .env.example .env
# 2. Replace ALL placeholders marked with REPLACE_WITH_xxx
# 3. Without a real MONGODB_URI, the API returns 503 and NOTHING works.
# =============================================================================

NODE_ENV=production
PORT=10000

# ---------------------------------------------------------------------------
# MongoDB (REQUIRED - without this, login/booking/quotations will NOT work)
# ---------------------------------------------------------------------------
# IMPORTANT: The URI MUST include the database name "/anbi-tech" before ?retryWrites
#
# Example for MongoDB Atlas (your cluster):
# mongodb+srv://anbitechsolutions_db_user:YOUR_PASSWORD@cluster0.bnczh2e.mongodb.net/anbi-tech?retryWrites=true&w=majority&appName=Cluster0
#
# Option B - Local MongoDB (for local testing only):
# MONGODB_URI=mongodb://127.0.0.1:27017/anbi-tech
# ---------------------------------------------------------------------------
MONGODB_URI=mongodb+srv://anbitechsolutions_db_user:REPLACE_WITH_PASSWORD@cluster0.bnczh2e.mongodb.net/anbi-tech?retryWrites=true&w=majority&appName=Cluster0

# ---------------------------------------------------------------------------
# JWT Secret (REQUIRED - used to sign login tokens)
# Generate a random string at https://randomkeygen.com/ or any long random string
# ---------------------------------------------------------------------------
JWT_SECRET=REPLACE_WITH_RANDOM_SECRET_KEY_MIN_32_CHARS_LONG
JWT_EXPIRE=7d

# ---------------------------------------------------------------------------
# Gmail SMTP (optional - only needed for email notifications)
# 1. Enable 2-Step Verification on your Google account
# 2. Go to https://myaccount.google.com/apppasswords
# 3. Generate an App Password for "Mail"
# 4. Paste the 16-character password below (no spaces)
# ---------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=anbitechsolutions@gmail.com
SMTP_PASS=REPLACE_WITH_GMAIL_APP_PASSWORD
ADMIN_EMAIL=anbitechsolutions@gmail.com

# ---------------------------------------------------------------------------
# Cloudinary (optional - only needed for file uploads in booking/quotations)
# 1. Sign up at https://cloudinary.com
# 2. Go to Dashboard → copy Cloud Name, API Key, API Secret
# ---------------------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=REPLACE_WITH_CLOUD_NAME
CLOUDINARY_API_KEY=REPLACE_WITH_API_KEY
CLOUDINARY_API_SECRET=REPLACE_WITH_API_SECRET

# ---------------------------------------------------------------------------
# Frontend URL (your deployed domain on Render)
# ---------------------------------------------------------------------------
FRONTEND_URL=https://anbi-tech.onrender.com
